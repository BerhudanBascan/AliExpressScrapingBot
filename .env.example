# ============================================
# AliExpress Dropshipping Bot - Konfigürasyon
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerlerinizi girin

# ---- Uygulama Ayarları ----
APP_NAME=AliExpress Dropshipping Pro
APP_SECRET_KEY=your-super-secret-key-change-this
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=5000

# ---- MongoDB Bağlantı Bilgileri ----
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=aliexpress_dropshipping

# ---- Redis Cache ----
REDIS_URL=redis://localhost:6379/0

# ---- eBay API Bilgileri ----
EBAY_ENABLED=true
EBAY_SANDBOX=true
EBAY_CLIENT_ID=YOUR_EBAY_CLIENT_ID
EBAY_CLIENT_SECRET=YOUR_EBAY_CLIENT_SECRET
EBAY_REFRESH_TOKEN=YOUR_EBAY_REFRESH_TOKEN
EBAY_MARKETPLACE_ID=EBAY_US

# ---- Walmart API Bilgileri ----
WALMART_ENABLED=true
WALMART_CLIENT_ID=YOUR_WALMART_CLIENT_ID
WALMART_CLIENT_SECRET=YOUR_WALMART_CLIENT_SECRET

# ---- Shopify API Bilgileri ----
SHOPIFY_ENABLED=true
SHOPIFY_SHOP_URL=your-store.myshopify.com
SHOPIFY_API_KEY=YOUR_SHOPIFY_API_KEY
SHOPIFY_API_PASSWORD=YOUR_SHOPIFY_API_PASSWORD
SHOPIFY_API_VERSION=2024-01

# ---- Amazon SP-API Bilgileri ----
AMAZON_ENABLED=false
AMAZON_SELLER_ID=YOUR_AMAZON_SELLER_ID
AMAZON_ACCESS_KEY=YOUR_AMAZON_ACCESS_KEY
AMAZON_SECRET_KEY=YOUR_AMAZON_SECRET_KEY
AMAZON_REFRESH_TOKEN=YOUR_AMAZON_REFRESH_TOKEN
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER

# ---- Etsy API Bilgileri ----
ETSY_ENABLED=false
ETSY_API_KEY=YOUR_ETSY_API_KEY
ETSY_SHARED_SECRET=YOUR_ETSY_SHARED_SECRET
ETSY_SHOP_ID=YOUR_ETSY_SHOP_ID

# ---- Proxy Bilgileri ----
PROXY_ENABLED=false
PROXY_LIST=http://proxy1:port,http://proxy2:port
PROXY_API_URL=https://your-proxy-provider.com/api
PROXY_API_KEY=YOUR_PROXY_API_KEY
PROXY_ROTATION_INTERVAL=300

# ---- Scraping Ayarları ----
SCRAPING_HEADLESS=true
SCRAPING_MAX_RETRIES=3
SCRAPING_DELAY_MIN=1.0
SCRAPING_DELAY_MAX=3.0
SCRAPING_USER_AGENT_ROTATION=true
SCRAPING_MAX_CONCURRENT=3

# ---- Bildirim Ayarları ----
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

EMAIL_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=your-email@gmail.com

# ---- Zamanlayıcı Ayarları ----
SCHEDULER_ENABLED=false
SCHEDULER_SCRAPE_INTERVAL=3600
SCHEDULER_UPLOAD_INTERVAL=1800
SCHEDULER_PRICE_CHECK_INTERVAL=7200

# ---- Sentry Hata Takibi ----
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
